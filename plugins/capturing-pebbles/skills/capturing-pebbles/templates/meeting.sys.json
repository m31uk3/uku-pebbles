{
  "$schema": "pebble-template/v0.3",
  "name": "meeting",
  "description": "Meeting capture. Calendar event + notes + action items.",
  "priority": 10,
  "match": {
    "source_app": "meeting"
  },
  "extends": "org",

  "fields": {
    "required": {
      "source": {
        "type": "object",
        "fields": {
          "app": { "type": "string", "const": "meeting" },
          "title": { "type": "string" },
          "start_time": { "type": "iso8601" },
          "end_time": { "type": "iso8601" }
        }
      }
    },
    "defaults": {
      "pebble_type": "experience_capture",
      "memory_kind": "episodic",
      "modality": "kinetic"
    },
    "optional": {
      "source.meeting_id": { "type": "string" },
      "source.organizer": { "type": "string" },
      "source.location": { "type": "string" },
      "source.provider": { "type": "string", "description": "chime | zoom | teams" },
      "people": { "type": "array" },
      "governed_by": { "type": "array", "description": "ontology links for fact verification" }
    }
  }
}
